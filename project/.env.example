# ============================================================================
# Insole Foot Classification - Environment Configuration
# Copy this file to `.env` and fill in real values
# ============================================================================

# ---------- App / runtime ----------
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=replace-me-with-a-long-random-string

# ---------- Database (PostgreSQL) ----------
POSTGRES_USER=insole_admin
POSTGRES_PASSWORD=change_me_securely
POSTGRES_DB=insole_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Composed DSN for SQLAlchemy / Prisma
DATABASE_URL=postgresql+psycopg2://insole_admin:change_me_securely@localhost:5432/insole_db
DATABASE_URL_ASYNC=postgresql+asyncpg://insole_admin:change_me_securely@localhost:5432/insole_db

# ---------- API server ----------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# ---------- Model paths ----------
MODEL_CHECKPOINT_DIR=./backend/model/checkpoints
DATA_DIR=./data
DEFAULT_CHECKPOINT=foot_classifier_v1.pt

# ---------- Training defaults ----------
TRAIN_BATCH_SIZE=16
TRAIN_NUM_EPOCHS=50
TRAIN_LEARNING_RATE=1e-4
TRAIN_NUM_WORKERS=4
TRAIN_DEVICE=auto

# ---------- Storage / uploads ----------
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25
